# macOS
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment & secrets
.class
.env
.env.*
!.env.example
gateway/agents/*/config/secrets.yaml
.codex/

# Node
node_modules/

# Build outputs
dist/
build/
coverage/
.vite/
**/target/

# TypeScript
*.tsbuildinfo

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.VSCodeCounter/

# Claude Code (CLAUDE.md is intentionally tracked for team sharing)

# Runtime / temp
*.pid
*.seed
*.pid.lock
tmp/
temp/

# Per-user runtime data (auto-generated by gateway)
gateway/users/

# Gateway runtime
gateway/data/

# Channel OOTB config is tracked under gateway/channels.
# Runtime data belongs under gateway/users and should not be committed if produced in the old layout.
gateway/channels/**/auth/
gateway/channels/**/inbox/
gateway/channels/**/processed/
gateway/channels/**/inbox-processed/
gateway/channels/**/outbox/
gateway/channels/**/logs/
gateway/channels/**/bindings.json
gateway/channels/**/events.json
gateway/channels/**/inbound-dedup.json
gateway/channels/**/login-state.json
gateway/channels/**/*.log
gateway/channels/**/*.pid

# Knowledge service runtime
knowledge-service/config.yaml
knowledge-service/data/
knowledge-service/data/**
knowledge-service/logs/

# Skill Market runtime
skill-market/data/*
!skill-market/data/skills/
!skill-market/data/skills/**
skill-market/logs/

# Agents runtime artifacts
gateway/agents/*/artifacts/
gateway/agents/*/state/logs/
gateway/agents/*/data/sessions/

# Config backups
*.bak
*.bak.*

# Playwright
/.playwright-cli/
/test-results/
test-output/
/output/
test/test-results/
test/playwright-report/

# Langfuse volumes (managed by Docker)
langfuse/pgdata/

.claude/
*/.dbg/