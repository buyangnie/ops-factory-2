<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring 属性绑定 -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="operation-intelligence"/>
    <springProperty scope="context" name="LOG_DIR" source="user.dir" defaultValue="./logs"/>

    <!-- 日志级别绑定 -->
    <springProperty scope="context" name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <springProperty scope="context" name="APP_LEVEL" source="logging.level.com.huawei.opsfactory.operationintelligence" defaultValue="INFO"/>
    <springProperty scope="context" name="SPRING_LEVEL" source="logging.level.org.springframework" defaultValue="WARN"/>
    <springProperty scope="context" name="REACTOR_LEVEL" source="logging.level.reactor" defaultValue="WARN"/>
    <springProperty scope="context" name="NETTY_LEVEL" source="logging.level.io.netty" defaultValue="WARN"/>

    <!-- 日志格式 -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [service=${APP_NAME} requestId=%X{requestId:-}] [%thread] %logger{36} - %msg%n%ex"/>

    <!-- 控制台输出 -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 - 按时间和大小滚动 -->
    <appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/operation-intelligence.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/operation-intelligence-%d{yyyy-MM-dd}-%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Logger 配置 -->
    <logger name="com.huawei.opsfactory.operationintelligence" level="${APP_LEVEL}"/>
    <logger name="org.springframework" level="${SPRING_LEVEL}"/>
    <logger name="reactor" level="${REACTOR_LEVEL}"/>
    <logger name="io.netty" level="${NETTY_LEVEL}"/>

    <!-- 根 Logger -->
    <root level="${ROOT_LEVEL}">
        <appender-ref ref="Console"/>
        <appender-ref ref="File"/>
    </root>
</configuration>