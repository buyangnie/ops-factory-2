    "operationIntelligenceKnowledgeGraph": {
        "collapsedRelationRules": [
            {
                "relationType": "contains",
                "targetEntityTypes": ["Host"],
                "threshold": 1
            }
        ],
        "resourceTreeHierarchyRules": [
            {
                "relationType": "contains",
                "mode": "hierarchy",
                "threshold": 1
            }
        ]
    },
    "logging": {
        "level": "info",
        "consoleEnabled": true,
        "bufferSize": 200,
        "sink": "console",
        "logDirectory": null
    },
    "port": 5173
}
